// Capvista Database Schema
// Architecture: Base User (auth sync) + separate Founder/Investor profile tables
// Auth: Supabase Auth → trigger auto-creates User + profile record

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USERS & AUTHENTICATION
// ============================================================================

enum UserRole {
  FOUNDER
  INVESTOR
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  firstName    String?
  lastName     String?
  phone        String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  founderProfile  FounderProfile?
  investorProfile InvestorProfile?

  verificationRecords VerificationRecord[]
  adminActions        AdminAction[]

  @@index([email])
  @@index([role])
}

// ============================================================================
// FOUNDER PROFILE
// ============================================================================

model FounderProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bio             String?  @db.Text
  linkedinUrl     String?
  yearsExperience Int?
  title           String?

  nin                String?
  bvn                String?
  ninVerified        Boolean   @default(false)
  bvnVerified        Boolean   @default(false)
  identityVerifiedAt DateTime?

  onboardingCompleted   Boolean   @default(false)
  onboardingCompletedAt DateTime?

  companiesOwned   Company[]        @relation("CompanyOwner")
  companiesFounded CompanyFounder[]

  @@index([userId])
}

// ============================================================================
// INVESTOR PROFILE
// ============================================================================

model InvestorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Step 1: Investor Profile
  investorType String?
  firmName     String?
  aum          String?

  // Step 2: Investment Preferences
  investmentFocus  String[]
  preferredLanes   String[]
  minimumCheckSize Float?
  maximumCheckSize Float?

  // Step 3: Suitability & Experience
  riskTolerance           String?
  liquidityNeeds          String?
  investmentHorizon       String?
  generalExperience       String?
  privateMarketExperience String?
  sourceOfFunds           String[]
  accreditationBasis      String?

  // Affiliations
  brokerAffiliated     Boolean @default(false)
  brokerDetails        String?
  seniorOfficer        Boolean @default(false)
  seniorOfficerCompany String?

  // Trusted Contact
  trustedContactName         String?
  trustedContactEmail        String?
  trustedContactPhone        String?
  trustedContactRelationship String?

  // Step 4: Identity / KYC
  countryOfResidence String?
  fullName           String?
  dateOfBirth        DateTime?
  citizenship        String?
  phone              String?
  residentialAddress String?
  city               String?
  stateProvince      String?
  postalCode         String?

  // Country-specific IDs
  nin            String?
  bvn            String?
  ssn            String?
  niNumber       String?
  passportNumber String?
  idType         String?
  idNumber       String?

  // Step 5: Risk Acknowledgements
  riskAcknowledged            Boolean @default(false)
  acknowledgePrivatePlacement Boolean @default(false)
  acknowledgeIlliquidity      Boolean @default(false)
  acknowledgeLossRisk         Boolean @default(false)
  acknowledgeNoGuarantee      Boolean @default(false)
  acknowledgeAccreditedStatus Boolean @default(false)

  // Legacy fields
  riskAcknowledgedAt DateTime?
  riskAcknowledgedIp String?
  kycDocumentUrl     String?

  // Compliance status
  verificationStatus String @default("PENDING")

  // Relationships
  investments    Investment[]
  capvistaEquity CapvistaHoldingsEquity[]

  @@index([userId])
  @@index([investorType])
  @@index([verificationStatus])
}

// ============================================================================
// COMPANIES
// ============================================================================

enum CompanyStage {
  PRE_REVENUE
  EARLY_REVENUE
  GROWTH
  PROFITABLE
}

enum BusinessModel {
  B2B
  B2C
  B2B2C
  B2G
  Marketplace
}

enum RevenueModel {
  TRANSACTIONAL
  SUBSCRIPTION
  ASSET_BACKED
}

enum Sector {
  TECHNOLOGY
  FINTECH
  LOGISTICS
  ENERGY
  CONSUMER_FMCG
  HEALTH
  AGRI_FOOD
  REAL_ESTATE
  INFRASTRUCTURE
  SAAS_TECH
  MANUFACTURING
}

model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   FounderProfile @relation("CompanyOwner", fields: [ownerId], references: [id])

  legalName              String
  tradingName            String?
  countryOfIncorporation String   @default("Nigeria")
  incorporationNumber    String   @unique
  incorporationDate      DateTime
  companyAddress         String
  operatingCountries     String[]
  website                String?
  logoUrl                String?
  officialEmailDomain    String

  cacVerificationStatus   String?
  sanctionsWatchlistCheck String?

  teamSize String?

  oneLineDescription  String
  detailedDescription String        @db.Text
  sector              Sector
  subsector           String?
  businessModel       BusinessModel
  revenueModel        RevenueModel
  stage               CompanyStage

  revenueStatus             String?
  revenueRange              String?
  primaryRevenueSource      String?
  keyMetrics                Json?
  majorCustomers            String[]
  geographicFootprint       String?
  regulatoryDependencies    String?
  bankAccountVerified       Boolean  @default(false)
  revenueVerificationMethod String?

  hasRaisedBefore          Boolean  @default(false)
  previousRaises           Json?
  founderOwnedPercent      Decimal? @db.Decimal(5, 2)
  externalInvestorsPercent Decimal? @db.Decimal(5, 2)
  notableInvestors         String[]

  topRisks                String[]
  materialThreats         String?
  singleSupplier          Boolean  @default(false)
  fxExposure              Boolean  @default(false)
  regulationDependent     Boolean  @default(false)
  infrastructureDependent Boolean  @default(false)

  preferredLane       DealLane?
  preferredInstrument InstrumentType?
  targetRaiseRange    String?
  primaryUseOfFunds   String?

  equityAcknowledgementAccepted  Boolean   @default(false)
  equityAcknowledgementTimestamp DateTime?
  equityAcknowledgementIp        String?
  equityIssuedToCapvistaHoldings Boolean   @default(false)

  currentMonitoringStatus MonitoringMode @default(NORMAL)

  founders            CompanyFounder[]
  verificationRecords VerificationRecord[]
  deals               Deal[]
  monitoringStatuses  MonitoringStatus[]
  capvistaEquity      CapvistaHoldingsEquity?

  @@index([incorporationNumber])
  @@index([sector])
  @@index([stage])
  @@index([ownerId])
}

model CompanyFounder {
  id        String   @id @default(cuid())
  companyId String
  founderId String
  role      String
  bio       String   @db.Text
  linkedinUrl     String?
  yearsExperience Int?
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())

  nin String?
  bvn String?

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  founder FounderProfile @relation(fields: [founderId], references: [id])

  @@unique([companyId, founderId])
  @@index([companyId])
  @@index([founderId])
}

// ============================================================================
// DEALS & INSTRUMENTS
// ============================================================================

enum DealLane {
  YIELD
  VENTURES
}

enum InstrumentType {
  REVENUE_SHARE_NOTE
  ASSET_BACKED_PARTICIPATION
  CONVERTIBLE_NOTE
  SAFE
  SPV_EQUITY
}

enum DealStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  LIVE
  CLOSED
  DEFAULTED
}

model Deal {
  id        String   @id @default(cuid())
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name           String
  lane           DealLane
  instrumentType InstrumentType
  status         DealStatus     @default(DRAFT)

  targetAmount      Decimal @db.Decimal(12, 2)
  minimumInvestment Decimal @db.Decimal(12, 2)
  raisedAmount      Decimal @db.Decimal(12, 2) @default(0)

  terms Json

  openedAt DateTime?
  closedAt DateTime?
  duration Int?

  pitchDeckUrl     String?
  financialDocsUrl String?
  termsSheetUrl    String?

  currentMonitoringStatus MonitoringMode @default(NORMAL)

  company            Company            @relation(fields: [companyId], references: [id])
  investments        Investment[]
  monitoringStatuses MonitoringStatus[]
  adminActions       AdminAction[]

  @@index([companyId])
  @@index([status])
  @@index([lane])
}

// ============================================================================
// INVESTMENTS
// ============================================================================

enum InvestmentStatus {
  COMMITTED
  FUNDED
  ACTIVE
  EXITED
  DEFAULTED
}

model Investment {
  id         String   @id @default(cuid())
  investorId String
  dealId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  commitmentAmount Decimal @db.Decimal(12, 2)
  fundedAmount     Decimal @db.Decimal(12, 2) @default(0)

  status InvestmentStatus @default(COMMITTED)

  committedAt DateTime @default(now())
  fundedAt    DateTime?

  totalReturned Decimal @db.Decimal(12, 2) @default(0)
  currentValue  Decimal @db.Decimal(12, 2) @default(0)

  investor           InvestorProfile     @relation(fields: [investorId], references: [id])
  deal               Deal                @relation(fields: [dealId], references: [id])
  escrowTransactions EscrowTransaction[]
  ownershipRecords   OwnershipRecord[]

  @@index([investorId])
  @@index([dealId])
  @@index([status])
}

// ============================================================================
// VERIFICATION
// ============================================================================

enum VerificationType {
  CAC
  NIN
  BVN
  BANK_ACCOUNT
  REVENUE
  ASSET
  IDENTITY
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

model VerificationRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String?
  companyId String?

  type            VerificationType
  status          VerificationStatus @default(PENDING)
  documentUrl     String?
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectionReason String?

  metadata Json?

  supersededBy String?

  user    User?    @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([companyId])
  @@index([type])
  @@index([status])
}

// ============================================================================
// ESCROW & TRANSACTIONS
// ============================================================================

enum TransactionDirection {
  INVESTOR_TO_ESCROW
  ESCROW_TO_COMPANY
  COMPANY_TO_INVESTOR
  ESCROW_TO_INVESTOR
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

model EscrowTransaction {
  id           String   @id @default(cuid())
  investmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  amount    Decimal              @db.Decimal(12, 2)
  direction TransactionDirection
  status    TransactionStatus    @default(PENDING)

  externalRef String?
  metadata    Json?

  investment Investment @relation(fields: [investmentId], references: [id])

  @@index([investmentId])
  @@index([status])
}

// ============================================================================
// OWNERSHIP RECORDS
// ============================================================================

enum OwnershipType {
  EQUITY_PERCENTAGE
  REVENUE_SHARE_PERCENTAGE
  CONVERTIBLE_RIGHTS
  ASSET_PARTICIPATION
}

model OwnershipRecord {
  id           String   @id @default(cuid())
  investmentId String
  createdAt    DateTime @default(now())

  ownershipType OwnershipType
  terms         Json
  issuedAt      DateTime @default(now())

  investment Investment @relation(fields: [investmentId], references: [id])

  @@index([investmentId])
}

// ============================================================================
// MONITORING
// ============================================================================

enum MonitoringMode {
  NORMAL
  WATCH
  INTERVENTION
}

model MonitoringStatus {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  dealId    String?

  mode              MonitoringMode
  triggeredBy       String
  notes             String?        @db.Text
  escalationHistory Json?

  resolvedAt DateTime?
  resolution String?

  company Company? @relation(fields: [companyId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])

  @@index([companyId])
  @@index([dealId])
  @@index([mode])
}

// ============================================================================
// ADMIN ACTIONS
// ============================================================================

enum AdminActionType {
  APPROVE_VERIFICATION
  REJECT_VERIFICATION
  APPROVE_DEAL
  REJECT_DEAL
  CHANGE_MONITORING_STATUS
  SUSPEND_COMPANY
  SUSPEND_USER
  MANUAL_INTERVENTION
}

model AdminAction {
  id        String   @id @default(cuid())
  adminId   String
  createdAt DateTime @default(now())

  actionType AdminActionType
  targetType String
  targetId   String

  dealId String?

  reason   String? @db.Text
  metadata Json?

  admin User  @relation(fields: [adminId], references: [id])
  deal  Deal? @relation(fields: [dealId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([actionType])
}

// ============================================================================
// CAPVISTA HOLDINGS EQUITY
// ============================================================================

model CapvistaHoldingsEquity {
  id         String   @id @default(cuid())
  companyId  String   @unique
  investorId String
  createdAt  DateTime @default(now())

  equityPercentage        Decimal  @default(1.0000) @db.Decimal(5, 4)
  isNonPreferential       Boolean  @default(true)
  issuedAt                DateTime @default(now())
  shareholderAgreementUrl String?

  company  Company         @relation(fields: [companyId], references: [id])
  investor InvestorProfile @relation(fields: [investorId], references: [id])

  @@index([companyId])
  @@index([investorId])
}