// Capvista Database Schema
// Architecture: Base User (auth sync) + separate Founder/Investor profile tables
// Auth: Supabase Auth → trigger auto-creates User + profile record

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USERS & AUTHENTICATION
// ============================================================================

enum UserRole {
  FOUNDER
  INVESTOR
  ADMIN
}

// Base user table — minimal, auto-synced from Supabase auth.users via trigger
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  firstName    String?
  lastName     String?
  phone        String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Profile references (exactly one will be populated based on role)
  founderProfile  FounderProfile?
  investorProfile InvestorProfile?

  // Shared relationships
  verificationRecords VerificationRecord[]
  adminActions        AdminAction[]

  @@index([email])
  @@index([role])
}

// ============================================================================
// FOUNDER PROFILE
// ============================================================================

model FounderProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Founder-specific fields
  bio             String?  @db.Text
  linkedinUrl     String?
  yearsExperience Int?
  title           String?  // e.g. "CEO", "CTO"

  // Identity verification (internal only — never exposed to investors)
  nin                String?
  bvn                String?
  ninVerified        Boolean   @default(false)
  bvnVerified        Boolean   @default(false)
  identityVerifiedAt DateTime?

  // Onboarding status
  onboardingCompleted   Boolean   @default(false)
  onboardingCompletedAt DateTime?

  // Relationships
  companiesOwned   Company[]        @relation("CompanyOwner")
  companiesFounded CompanyFounder[]

  @@index([userId])
}

// ============================================================================
// INVESTOR PROFILE
// ============================================================================

enum InvestorType {
  INDIVIDUAL
  INSTITUTIONAL
  FAMILY_OFFICE
  FUND
  ANGEL
}

enum AccreditationStatus {
  PENDING
  VERIFIED
  EXPIRED
  REJECTED
}

model InvestorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Investor-specific fields
  investorType     InvestorType?
  firmName         String?
  aum              Decimal?  @db.Decimal(15, 2)
  investmentFocus  String[]
  preferredLanes   String[]
  minimumCheckSize Decimal?  @db.Decimal(12, 2)
  maximumCheckSize Decimal?  @db.Decimal(12, 2)

  // Risk acknowledgement (required before investing)
  riskAcknowledgedAt DateTime?
  riskAcknowledgedIp String?

  // Accreditation / KYC
  accreditationStatus AccreditationStatus @default(PENDING)
  accreditedAt        DateTime?
  kycDocumentUrl      String?

  // Relationships
  investments    Investment[]
  capvistaEquity CapvistaHoldingsEquity[]

  @@index([userId])
  @@index([investorType])
  @@index([accreditationStatus])
}

// ============================================================================
// COMPANIES
// ============================================================================

enum CompanyStage {
  PRE_REVENUE
  EARLY_REVENUE
  GROWTH
  PROFITABLE
}

enum BusinessModel {
  B2B
  B2C
  B2B2C
}

enum RevenueModel {
  TRANSACTIONAL
  SUBSCRIPTION
  ASSET_BACKED
}

enum Sector {
  FINTECH
  LOGISTICS
  ENERGY
  CONSUMER_FMCG
  HEALTH
  AGRI_FOOD
  REAL_ESTATE
  INFRASTRUCTURE
  SAAS_TECH
  MANUFACTURING
}

model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Owner — references FounderProfile (not User)
  ownerId String
  owner   FounderProfile @relation("CompanyOwner", fields: [ownerId], references: [id])

  // 1️⃣ Identity (Foundational)
  legalName              String
  tradingName            String?
  countryOfIncorporation String   @default("Nigeria")
  incorporationNumber    String   @unique // CAC number
  incorporationDate      DateTime
  companyAddress         String
  operatingCountries     String[]
  website                String?
  logoUrl              String?
  officialEmailDomain    String

  // Internal only
  cacVerificationStatus   String?
  sanctionsWatchlistCheck String?

  // 2️⃣ Founders & Team
  teamSize String? // Enum: founders_only, 1-5, 6-20, 21-50, 50+

  // 3️⃣ Company Overview
  oneLineDescription  String
  detailedDescription String        @db.Text
  sector              Sector
  businessModel       BusinessModel
  revenueModel        RevenueModel
  stage               CompanyStage

  // 4️⃣ Traction & Operations
  revenueStatus             String?
  revenueRange              String?
  primaryRevenueSource      String?
  keyMetrics                Json?
  majorCustomers            String[]
  geographicFootprint       String?
  regulatoryDependencies    String?
  bankAccountVerified       Boolean  @default(false)
  revenueVerificationMethod String?

  // 5️⃣ Capital & History
  hasRaisedBefore          Boolean  @default(false)
  previousRaises           Json?
  founderOwnedPercent      Decimal? @db.Decimal(5, 2)
  externalInvestorsPercent Decimal? @db.Decimal(5, 2)
  notableInvestors         String[]

  // 6️⃣ Risk & Reality
  topRisks                String[]
  materialThreats         String?
  singleSupplier          Boolean  @default(false)
  fxExposure              Boolean  @default(false)
  regulationDependent     Boolean  @default(false)
  infrastructureDependent Boolean  @default(false)

  // 7️⃣ Fundraising Intent
  preferredLane       DealLane?
  preferredInstrument InstrumentType?
  targetRaiseRange    String?
  primaryUseOfFunds   String?

  // 8️⃣ Platform Equity Acknowledgement
  equityAcknowledgementAccepted  Boolean   @default(false)
  equityAcknowledgementTimestamp DateTime?
  equityAcknowledgementIp        String?
  equityIssuedToCapvistaHoldings Boolean   @default(false)

  // Monitoring
  currentMonitoringStatus MonitoringMode @default(NORMAL)

  // Relationships
  founders            CompanyFounder[]
  verificationRecords VerificationRecord[]
  deals               Deal[]
  monitoringStatuses  MonitoringStatus[]
  capvistaEquity      CapvistaHoldingsEquity?

  @@index([incorporationNumber])
  @@index([sector])
  @@index([stage])
  @@index([ownerId])
}

model CompanyFounder {
  id        String   @id @default(cuid())
  companyId String
  founderId String   // References FounderProfile.id (not User.id)
  role      String   // CEO, CTO, etc.
  bio       String   @db.Text
  linkedinUrl     String?
  yearsExperience Int?
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())

  // Internal only
  nin String?
  bvn String?

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  founder FounderProfile @relation(fields: [founderId], references: [id])

  @@unique([companyId, founderId])
  @@index([companyId])
  @@index([founderId])
}

// ============================================================================
// DEALS & INSTRUMENTS
// ============================================================================

enum DealLane {
  YIELD
  VENTURES
}

enum InstrumentType {
  REVENUE_SHARE_NOTE         // Yield
  ASSET_BACKED_PARTICIPATION // Yield
  CONVERTIBLE_NOTE           // Ventures
  SAFE                       // Ventures
  SPV_EQUITY                 // Ventures
}

enum DealStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  LIVE
  CLOSED
  DEFAULTED
}

model Deal {
  id        String   @id @default(cuid())
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Basic info
  name           String
  lane           DealLane
  instrumentType InstrumentType
  status         DealStatus     @default(DRAFT)

  // Raise details
  targetAmount      Decimal @db.Decimal(12, 2)
  minimumInvestment Decimal @db.Decimal(12, 2)
  raisedAmount      Decimal @db.Decimal(12, 2) @default(0)

  // Terms (stored as JSON for flexibility per instrument)
  terms Json

  // Timeline
  openedAt DateTime?
  closedAt DateTime?
  duration Int?

  // Documents
  pitchDeckUrl     String?
  financialDocsUrl String?
  termsSheetUrl    String?

  // Monitoring
  currentMonitoringStatus MonitoringMode @default(NORMAL)

  // Relationships
  company            Company            @relation(fields: [companyId], references: [id])
  investments        Investment[]
  monitoringStatuses MonitoringStatus[]
  adminActions       AdminAction[]

  @@index([companyId])
  @@index([status])
  @@index([lane])
}

// ============================================================================
// INVESTMENTS
// ============================================================================

enum InvestmentStatus {
  COMMITTED
  FUNDED
  ACTIVE
  EXITED
  DEFAULTED
}

model Investment {
  id         String   @id @default(cuid())
  investorId String   // References InvestorProfile.id (not User.id)
  dealId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Amounts
  commitmentAmount Decimal @db.Decimal(12, 2)
  fundedAmount     Decimal @db.Decimal(12, 2) @default(0)

  // Status
  status InvestmentStatus @default(COMMITTED)

  // Timeline
  committedAt DateTime @default(now())
  fundedAt    DateTime?

  // Returns tracking
  totalReturned Decimal @db.Decimal(12, 2) @default(0)
  currentValue  Decimal @db.Decimal(12, 2) @default(0)

  // Relationships
  investor           InvestorProfile     @relation(fields: [investorId], references: [id])
  deal               Deal                @relation(fields: [dealId], references: [id])
  escrowTransactions EscrowTransaction[]
  ownershipRecords   OwnershipRecord[]

  @@index([investorId])
  @@index([dealId])
  @@index([status])
}

// ============================================================================
// VERIFICATION
// ============================================================================

enum VerificationType {
  CAC
  NIN
  BVN
  BANK_ACCOUNT
  REVENUE
  ASSET
  IDENTITY
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

model VerificationRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subject (either user or company)
  userId    String?
  companyId String?

  // Verification details
  type            VerificationType
  status          VerificationStatus @default(PENDING)
  documentUrl     String?
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectionReason String?

  // Metadata
  metadata Json?

  // Immutable — never delete, only supersede
  supersededBy String?

  // Relationships
  user    User?    @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([companyId])
  @@index([type])
  @@index([status])
}

// ============================================================================
// ESCROW & TRANSACTIONS
// ============================================================================

enum TransactionDirection {
  INVESTOR_TO_ESCROW
  ESCROW_TO_COMPANY
  COMPANY_TO_INVESTOR
  ESCROW_TO_INVESTOR
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

model EscrowTransaction {
  id           String   @id @default(cuid())
  investmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  amount    Decimal              @db.Decimal(12, 2)
  direction TransactionDirection
  status    TransactionStatus    @default(PENDING)

  externalRef String?
  metadata    Json?

  investment Investment @relation(fields: [investmentId], references: [id])

  @@index([investmentId])
  @@index([status])
}

// ============================================================================
// OWNERSHIP RECORDS
// ============================================================================

enum OwnershipType {
  EQUITY_PERCENTAGE
  REVENUE_SHARE_PERCENTAGE
  CONVERTIBLE_RIGHTS
  ASSET_PARTICIPATION
}

model OwnershipRecord {
  id           String   @id @default(cuid())
  investmentId String
  createdAt    DateTime @default(now())

  ownershipType OwnershipType
  terms         Json
  issuedAt      DateTime @default(now())

  investment Investment @relation(fields: [investmentId], references: [id])

  @@index([investmentId])
}

// ============================================================================
// MONITORING
// ============================================================================

enum MonitoringMode {
  NORMAL
  WATCH
  INTERVENTION
}

model MonitoringStatus {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  dealId    String?

  mode              MonitoringMode
  triggeredBy       String
  notes             String?        @db.Text
  escalationHistory Json?

  resolvedAt DateTime?
  resolution String?

  company Company? @relation(fields: [companyId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])

  @@index([companyId])
  @@index([dealId])
  @@index([mode])
}

// ============================================================================
// ADMIN ACTIONS
// ============================================================================

enum AdminActionType {
  APPROVE_VERIFICATION
  REJECT_VERIFICATION
  APPROVE_DEAL
  REJECT_DEAL
  CHANGE_MONITORING_STATUS
  SUSPEND_COMPANY
  SUSPEND_USER
  MANUAL_INTERVENTION
}

model AdminAction {
  id        String   @id @default(cuid())
  adminId   String
  createdAt DateTime @default(now())

  actionType AdminActionType
  targetType String
  targetId   String

  dealId String?

  reason   String? @db.Text
  metadata Json?

  admin User  @relation(fields: [adminId], references: [id])
  deal  Deal? @relation(fields: [dealId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([actionType])
}

// ============================================================================
// CAPVISTA HOLDINGS EQUITY
// ============================================================================

model CapvistaHoldingsEquity {
  id         String   @id @default(cuid())
  companyId  String   @unique
  investorId String   // References InvestorProfile.id
  createdAt  DateTime @default(now())

  equityPercentage        Decimal  @default(1.0000) @db.Decimal(5, 4)
  isNonPreferential       Boolean  @default(true)
  issuedAt                DateTime @default(now())
  shareholderAgreementUrl String?

  company  Company         @relation(fields: [companyId], references: [id])
  investor InvestorProfile @relation(fields: [investorId], references: [id])

  @@index([companyId])
  @@index([investorId])
}