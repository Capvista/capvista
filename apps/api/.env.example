DATABASE_URL="postgresql://user:password@host:port/database"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed CORS origins.
# Defaults: dev → localhost:3000,localhost:8081,localhost:19006 | prod → https://fastgas.ng,https://api.fastgas.ng
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006
ADMIN_INVITE_CODE=your-admin-invite-code
