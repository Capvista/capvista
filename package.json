{
  "name": "capvista",
  "version": "0.1.0",
  "private": true,
  "description": "Private markets infrastructure platform for African startups",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @capvista/database generate",
    "db:push": "pnpm --filter @capvista/database push",
    "db:migrate": "pnpm --filter @capvista/database migrate:dev",
    "db:studio": "pnpm --filter @capvista/database studio"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.12.0"
}